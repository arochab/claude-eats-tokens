.env
__pycache__/
*.pyc
.DS_Store

# Claude Code local session settings (per-machine)
.claude/settings.local.json

# Données poussées localement (régénérées par le PC)
data/usage.json

# Render ephemeral / local temp
*.log

# Secrets locaux (NE JAMAIS committer) — un par machine
secret.local.bat
claudeeatstoken*.mp4

# Secrets de passage : posés le temps d'une manip, lus, puis supprimés.
# Le motif est large exprès — il vaut mieux ignorer un fichier de trop qu'en
# laisser filer un seul. Le second motif couvre le ".txt" que Notepad rajoute
# en double malgré des guillemets dans "Enregistrer sous" (vécu le 17/07/2026 :
# sk.local.txt.txt n'était PAS ignoré par *.local.txt seul — faille corrigée
# avant que le fichier ne soit jamais ajouté à un commit).
*.local.txt
*.local.txt*
sk.local.txt
